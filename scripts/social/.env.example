# ============================================================
# Trao Tay — Social Auto-Poster credentials
# Sao chép file này thành .env rồi điền giá trị thật
# KHÔNG commit file .env lên git
# ============================================================

# ── Facebook Page ────────────────────────────────────────────
# 1. Tạo Page "Trao Tay" tại facebook.com/pages/create
# 2. Vào developers.facebook.com → tạo App → Graph API Explorer
# 3. Permission: pages_manage_posts, pages_read_engagement
# 4. Đổi sang Long-lived Token (60 ngày)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# ── Instagram ────────────────────────────────────────────────
# Dùng chung Facebook Developer App
# 1. Instagram account phải là Business hoặc Creator
# 2. Link Instagram với Facebook Page
# 3. Permission: instagram_content_publish, instagram_basic
# 4. IG_ACCOUNT_ID: gọi GET /me/accounts rồi lấy instagram_business_account.id
# 5. IG_DEFAULT_IMAGE_URL: ảnh OG mặc định đính kèm mỗi bài (Instagram bắt buộc có ảnh)
IG_ACCOUNT_ID=
IG_ACCESS_TOKEN=
IG_DEFAULT_IMAGE_URL=https://traotay.com.vn/og-image.jpg

# ── Threads ──────────────────────────────────────────────────
# Dùng chung Facebook Developer App
# 1. Add product: Threads API
# 2. Permission: threads_content_publish
# 3. THREADS_USER_ID: GET https://graph.threads.net/v1.0/me?access_token=TOKEN
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

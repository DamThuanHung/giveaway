{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/check-commit-evidence.sh" },
          { "type": "command", "command": "bash .claude/check-schema-adr.sh" },
          { "type": "command", "command": "bash .claude/check-deploy-readiness.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/inject-deploy-reminder.sh" }
        ]
      }
    ]
  }
}

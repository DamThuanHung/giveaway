generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [unaccent]
}

model User {
  id                 String           @id @default(cuid())
  email              String?          @unique
  name               String?
  createdAt          DateTime         @default(now())
  avatar             String?
  fcmToken           String?
  isBanned           Boolean          @default(false)
  role               String           @default("user")
  updatedAt          DateTime         @updatedAt
  phone              String?          @unique
  isPhoneVerified    Boolean          @default(false)
  deletedAt          DateTime?
  blockedByUsers     BlockedUser[]    @relation("BlockedRelation")
  blockedUsers       BlockedUser[]    @relation("BlockerRelation")
  followers          Follow[]         @relation("FollowingRelation")
  following          Follow[]         @relation("FollowerRelation")
  chatAsBuyer        ChatRoom[]       @relation("BuyerRooms")
  chatAsSeller       ChatRoom[]       @relation("SellerRooms")
  favorites          Favorite[]
  sentMessages       Message[]        @relation("MessageSender")
  notifications      Notification[]
  posts              Post[]
  reports            Report[]
  reviewsReceived    Review[]         @relation("ReviewReceived")
  reviewsGiven       Review[]         @relation("ReviewGiven")
  postsCompletedWith Post[]           @relation("PostCompletedPartner")
  keywordAlerts      KeywordAlert[]
  bumpOrders         BumpOrder[]
  adminActions       AdminActionLog[] @relation("AdminActionLog_admin")
  webPushSubscriptions WebPushSubscription[]
}

model Post {
  title               String
  description         String
  price               Int         @default(0)
  createdAt           DateTime    @default(now())
  addressDetail       String      @default("")
  district            String      @default("")
  imageLabel          String      @default("")
  images              String[]
  itemCategory        String      @default("other")
  listingType         String      @default("sell")
  province            String      @default("")
  status              String      @default("available")
  ward                String      @default("")
  id                  String      @id @default(cuid())
  latitude            Float       @default(0.0)
  longitude           Float       @default(0.0)
  authorId            String?
  updatedAt           DateTime    @updatedAt
  viewCount           Int         @default(0)
  bumpedAt            DateTime?
  boostTier           Int         @default(0) // 0=none 1=free 2=plus 3=vip
  postType            String      @default("item") // item | realestate | service
  subType             String? // rent | sell (BĐS)
  area                Float? // m² (BĐS)
  bedrooms            Int? // số phòng ngủ (BĐS)
  priceUnit           String? // month | total | sqm | hour | day
  serviceArea         String? // phạm vi phục vụ (Dịch vụ & Thợ)
  // Trạng thái giao dịch hoàn tất — author bấm "Hoàn thành" → set 2 field này
  // status đổi sang 'done'. Reviews chỉ tạo được khi post đã 'done'.
  completedWithUserId String? // partner mà author đã giao dịch
  completedAt         DateTime?
  chatRooms           ChatRoom[]
  favorites           Favorite[]
  bumpOrders          BumpOrder[]
  reviews             Review[]
  postViews           PostView[]
  author              User?       @relation(fields: [authorId], references: [id])
  completedWith       User?       @relation("PostCompletedPartner", fields: [completedWithUserId], references: [id])
  reports             Report[]

  @@index([status])
  @@index([province])
  @@index([listingType])
  @@index([itemCategory])
  @@index([authorId])
  @@index([createdAt])
  @@index([status, listingType])
  @@index([status, itemCategory])
  @@index([postType])
  @@index([bumpedAt])
}

model BumpOrder {
  id           String    @id @default(cuid())
  userId       String
  postId       String
  package      String // "plus_3d" | "vip_7d"
  tier         Int // 2=plus | 3=vip
  amount       Int // giá VNĐ: 5000 | 15000
  status       String    @default("pending") // pending | paid | expired | cancelled | refunded
  payosOrderId String?   @unique // mã đơn PayOS
  expiredAt    DateTime? // null khi chưa paid
  createdAt    DateTime  @default(now())
  // Khi admin hoàn tiền: set status='refunded' + 2 field này. Tiền thật do
  // admin tự hoàn qua dashboard PayOS hoặc chuyển khoản ngược. Field này chỉ
  // tracking internal + reverse boost effect (post.boostTier về 0).
  refundedAt   DateTime?
  refundReason String?
  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([status])
  @@index([expiredAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

/// Aggregate lượt xem bài đăng theo ngày (UTC day boundary).
/// Mỗi (postId, date) chỉ có 1 row, count tăng dần qua upsert.
/// Dùng cho admin dashboard "Top bài lượt xem theo period" — ADR-0010.
/// `Post.viewCount` lifetime vẫn được giữ nguyên cho mobile/web.
model PostView {
  id     String   @id @default(cuid())
  postId String
  date   DateTime // truncated to UTC midnight (start of day)
  count  Int      @default(0)
  post   Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, date])
  @@index([date])
  @@index([postId, date])
}

model Report {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ChatRoom {
  id        String    @id @default(cuid())
  buyerId   String
  postId    String
  sellerId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  buyer     User      @relation("BuyerRooms", fields: [buyerId], references: [id])
  post      Post      @relation(fields: [postId], references: [id])
  seller    User      @relation("SellerRooms", fields: [sellerId], references: [id])
  messages  Message[]

  @@unique([buyerId, sellerId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  text      String
  createdAt DateTime @default(now())
  senderId  String
  isRead    Boolean  @default(false)
  metadata  String?
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId])
  @@index([roomId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

// Review user-to-user gắn với 1 bài đăng cụ thể.
// Chỉ tạo được khi post.status='done' (author đã bấm "Hoàn thành").
// Cả 2 chiều: author review buyer/recipient + buyer/recipient review author.
// Cho edit trong 24h sau submit, sau đó freeze.
model Review {
  id         String   @id @default(cuid())
  postId     String
  reviewerId String
  revieweeId String
  rating     Int // 1-5
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("ReviewReceived", fields: [revieweeId], references: [id])
  reviewer   User     @relation("ReviewGiven", fields: [reviewerId], references: [id])

  @@unique([postId, reviewerId])
  @@index([revieweeId])
  @@index([postId])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlockedRelation", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("BlockerRelation", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowerRelation", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowingRelation", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model KeywordAlert {
  id        String   @id @default(cuid())
  userId    String
  keyword   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
  @@index([userId])
  // PB3 (Tier 4): index keyword cho fast lookup trong notifyMatchingUsers SQL.
  // Khi scale 10k+ alerts, tránh full-table scan.
  @@index([keyword])
}

model BannedIdentity {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  createdAt DateTime @default(now())
}

/// Danh mục cho Post.itemCategory. Hiện tại Post.itemCategory là String —
/// admin quản lý Category table này, client fetch danh sách qua /category.
/// Khi admin disable 1 category: bài cũ vẫn giữ value, nhưng UI client sẽ
/// không hiện trong picker → không có post mới với category đó.
model Category {
  id        String   @id @default(cuid())
  value     String   @unique // slug "electronics" — match Post.itemCategory
  label     String // "Điện tử"
  icon      String? // path asset hoặc URL icon
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String // post.hide, post.unhide, post.delete, user.ban, user.unban, user.role, report.resolve, report.dismiss, post.softdelete
  targetType String // post | user | report
  targetId   String
  metadata   Json? // {oldRole, newRole, reason, isBanned, ...}
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActionLog_admin", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

/// Ghi nhận mỗi lượt tải app (APK/Play Store) qua redirect endpoint /download/:platform.
/// Dùng để thống kê "lượt tải app" trong admin analytics tab.
model AppDownloadLog {
  id        String   @id @default(cuid())
  platform  String   @default("android") // "android" | "ios"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([platform, createdAt])
}

/// Web Push subscription cho mỗi browser của user. Khác FCM (mobile native)
/// — Web Push dùng VAPID + Push API browser. 1 user có thể có nhiều subscription
/// (Chrome desktop + Firefox + Edge). Backend gửi push qua web-push npm với
/// VAPID_PRIVATE_KEY ký vào header request.
///
/// Khi push fail với 410 Gone → endpoint expire → xóa khỏi DB (prune).
/// Khi user logout → xóa tất cả sub của user trên browser hiện tại (theo endpoint).
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique // URL push service (FCM/Mozilla/Apple)
  p256dh    String // public key client cho encryption
  auth      String // auth secret cho encryption
  userAgent String? // tên browser để admin debug
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

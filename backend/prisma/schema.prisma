generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  avatar    String?
  role      String   @default("user")   // "user" | "moderator" | "admin"
  fcmToken  String?
  isBanned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts            Post[]
  favorites        Favorite[]
  reports          Report[]
  notifications    Notification[]
  chatAsBuyer      ChatRoom[]     @relation("BuyerRooms")
  chatAsSeller     ChatRoom[]     @relation("SellerRooms")
  sentMessages     Message[]      @relation("MessageSender")
  dealsAsRequester Deal[]         @relation("DealRequester")
  dealsAsOwner     Deal[]         @relation("DealOwner")
  reviewsGiven     Review[]       @relation("ReviewGiven")
  reviewsReceived  Review[]       @relation("ReviewReceived")
}

// ─── POST ────────────────────────────────────────────────
model Post {
  id            String   @id @default(cuid())
  title         String
  description   String
  price         Int      @default(0)
  latitude      Float    @default(0.0)
  longitude     Float    @default(0.0)
  province      String   @default("")
  district      String   @default("")
  ward          String   @default("")
  addressDetail String   @default("")
  listingType   String   @default("sell")      // "sell" | "give"
  itemCategory  String   @default("other")
  imageLabel    String   @default("")
  status        String   @default("available") // "available" | "reserved" | "done"
  viewCount     Int      @default(0)
  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  favorites Favorite[]
  chatRooms ChatRoom[]
  reports   Report[]
  deals     Deal[]

  @@index([status])
  @@index([province])
  @@index([listingType])
  @@index([itemCategory])
  @@index([authorId])
  @@index([createdAt])
  @@index([status, listingType])
  @@index([status, itemCategory])
}

// ─── FAVORITE ────────────────────────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

// ─── REPORT ──────────────────────────────────────────────
model Report {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  reason    String
  status    String   @default("pending") // "pending" | "resolved" | "dismissed"
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

// ─── CHAT ROOM ───────────────────────────────────────────
model ChatRoom {
  id        String    @id @default(cuid())
  postId    String
  buyerId   String
  sellerId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  post     Post      @relation(fields: [postId], references: [id])
  buyer    User      @relation("BuyerRooms",  fields: [buyerId],  references: [id])
  seller   User      @relation("SellerRooms", fields: [sellerId], references: [id])
  messages Message[]

  @@unique([postId, buyerId])
}

// ─── MESSAGE ─────────────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  text      String
  senderId  String
  roomId    String
  metadata  String?  // JSON: { type:'deal', dealId, status, userMessage, postTitle }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  sender User     @relation("MessageSender", fields: [senderId], references: [id])
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([roomId, createdAt])
}

// ─── NOTIFICATION ─────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "chat" | "deal" | "review" | "system"
  title     String
  body      String
  data      String?  // JSON string cho deep link
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

// ─── DEAL ────────────────────────────────────────────────
model Deal {
  id          String   @id @default(cuid())
  postId      String
  requesterId String
  ownerId     String
  status      String   @default("pending") // "pending"|"accepted"|"rejected"|"completed"|"cancelled"
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post      Post     @relation(fields: [postId],      references: [id])
  requester User     @relation("DealRequester", fields: [requesterId], references: [id])
  owner     User     @relation("DealOwner",     fields: [ownerId],     references: [id])
  reviews   Review[]

  @@index([requesterId])
  @@index([ownerId])
  @@index([status])
}

// ─── REVIEW ──────────────────────────────────────────────
model Review {
  id         String   @id @default(cuid())
  dealId     String
  reviewerId String
  revieweeId String
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  deal     Deal @relation(fields: [dealId],     references: [id])
  reviewer User @relation("ReviewGiven",    fields: [reviewerId], references: [id])
  reviewee User @relation("ReviewReceived", fields: [revieweeId], references: [id])

  @@unique([dealId, reviewerId])
}

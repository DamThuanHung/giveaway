generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [unaccent]
}

model User {
  id               String         @id @default(cuid())
  email            String?        @unique
  name             String?
  createdAt        DateTime       @default(now())
  avatar           String?
  fcmToken         String?
  isBanned         Boolean        @default(false)
  role             String         @default("user")
  updatedAt        DateTime       @updatedAt
  phone            String?        @unique
  isPhoneVerified  Boolean        @default(false)
  deletedAt        DateTime?
  blockedByUsers   BlockedUser[]  @relation("BlockedRelation")
  blockedUsers     BlockedUser[]  @relation("BlockerRelation")
  followers        Follow[]       @relation("FollowingRelation")
  following        Follow[]       @relation("FollowerRelation")
  chatAsBuyer      ChatRoom[]     @relation("BuyerRooms")
  chatAsSeller     ChatRoom[]     @relation("SellerRooms")
  dealsAsOwner     Deal[]         @relation("DealOwner")
  dealsAsRequester Deal[]         @relation("DealRequester")
  favorites        Favorite[]
  sentMessages     Message[]      @relation("MessageSender")
  notifications    Notification[]
  posts            Post[]
  reports          Report[]
  reviewsReceived  Review[]       @relation("ReviewReceived")
  reviewsGiven     Review[]       @relation("ReviewGiven")
  keywordAlerts    KeywordAlert[]
  bumpOrders       BumpOrder[]
  adminActions     AdminActionLog[] @relation("AdminActionLog_admin")
}

model Post {
  title         String
  description   String
  price         Int        @default(0)
  createdAt     DateTime   @default(now())
  addressDetail String     @default("")
  district      String     @default("")
  imageLabel    String     @default("")
  images        String[]
  itemCategory  String     @default("other")
  listingType   String     @default("sell")
  province      String     @default("")
  status        String     @default("available")
  ward          String     @default("")
  id            String     @id @default(cuid())
  latitude      Float      @default(0.0)
  longitude     Float      @default(0.0)
  authorId      String?
  updatedAt     DateTime   @updatedAt
  viewCount     Int        @default(0)
  bumpedAt      DateTime?
  boostTier     Int        @default(0)  // 0=none 1=free 2=plus 3=vip
  postType      String     @default("item")      // item | realestate | service
  subType       String?                           // rent | sell (BĐS)
  area          Float?                            // m² (BĐS)
  bedrooms      Int?                              // số phòng ngủ (BĐS)
  priceUnit     String?                           // month | total | sqm | hour | day
  serviceArea   String?                           // phạm vi phục vụ (Dịch vụ & Thợ)
  chatRooms     ChatRoom[]
  deals         Deal[]
  favorites     Favorite[]
  bumpOrders    BumpOrder[]
  author        User?      @relation(fields: [authorId], references: [id])
  reports       Report[]

  @@index([status])
  @@index([province])
  @@index([listingType])
  @@index([itemCategory])
  @@index([authorId])
  @@index([createdAt])
  @@index([status, listingType])
  @@index([status, itemCategory])
  @@index([postType])
  @@index([bumpedAt])
}

model BumpOrder {
  id            String    @id @default(cuid())
  userId        String
  postId        String
  package       String    // "plus_3d" | "vip_7d"
  tier          Int       // 2=plus | 3=vip
  amount        Int       // giá VNĐ: 5000 | 15000
  status        String    @default("pending") // pending | paid | expired | cancelled
  payosOrderId  String?   @unique            // mã đơn PayOS
  expiredAt     DateTime?                    // null khi chưa paid
  createdAt     DateTime  @default(now())
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([status])
  @@index([expiredAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

model Report {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ChatRoom {
  id        String    @id @default(cuid())
  buyerId   String
  postId    String
  sellerId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  buyer     User      @relation("BuyerRooms", fields: [buyerId], references: [id])
  post      Post      @relation(fields: [postId], references: [id])
  seller    User      @relation("SellerRooms", fields: [sellerId], references: [id])
  messages  Message[]

  @@unique([buyerId, sellerId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  text      String
  createdAt DateTime @default(now())
  senderId  String
  isRead    Boolean  @default(false)
  metadata  String?
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId])
  @@index([roomId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model Deal {
  id          String   @id @default(cuid())
  postId      String
  requesterId String
  ownerId     String
  status      String   @default("pending")
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation("DealOwner", fields: [ownerId], references: [id])
  post        Post     @relation(fields: [postId], references: [id])
  requester   User     @relation("DealRequester", fields: [requesterId], references: [id])
  reviews     Review[]

  @@index([requesterId])
  @@index([ownerId])
  @@index([status])
}

model Review {
  id         String   @id @default(cuid())
  dealId     String
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  deal       Deal     @relation(fields: [dealId], references: [id])
  reviewee   User     @relation("ReviewReceived", fields: [revieweeId], references: [id])
  reviewer   User     @relation("ReviewGiven", fields: [reviewerId], references: [id])

  @@unique([dealId, reviewerId])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlockedRelation", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("BlockerRelation", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowerRelation", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowingRelation", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model KeywordAlert {
  id        String   @id @default(cuid())
  userId    String
  keyword   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
  @@index([userId])
}

model BannedIdentity {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  createdAt DateTime @default(now())
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // post.hide, post.unhide, post.delete, user.ban, user.unban, user.role, report.resolve, report.dismiss, post.softdelete
  targetType String   // post | user | report
  targetId   String
  metadata   Json?    // {oldRole, newRole, reason, isBanned, ...}
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActionLog_admin", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

# ══════════════════════════════════════════════════════════════════
# .env.example — copy sang .env (dev) hoặc .env.docker (prod)
# ══════════════════════════════════════════════════════════════════

# ─── Runtime ───────────────────────────────────────────────────────
NODE_ENV="development"                  # production | development
PORT=3800
BASE_URL="http://localhost:3800"        # Public URL của server (dùng cho log + fallback PayOS)
PUBLIC_URL=""                           # Bắt buộc production: URL public (https). Ngrok khi dev + PayOS

# ─── CORS ──────────────────────────────────────────────────────────
# Production: comma-separated origin, VD "https://traotay.com.vn,https://www.traotay.com.vn"
# Rỗng khi dev để cho phép mọi origin (thuận tiện test)
CORS_ORIGIN=""

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/traotay"

# ─── JWT ───────────────────────────────────────────────────────────
# openssl rand -base64 64
JWT_SECRET="CHANGE_ME_TO_LONG_RANDOM_STRING"

# ─── Admin ─────────────────────────────────────────────────────────
# Comma-separated email — user có role admin khi login. Không có fallback hardcode.
ADMIN_EMAILS=""

# ─── Firebase Cloud Messaging (FCM) ────────────────────────────────
# Nội dung file service account JSON (1 dòng) HOẶC dùng GOOGLE_APPLICATION_CREDENTIALS
FCM_SERVICE_ACCOUNT=""

# ─── MinIO (S3-compatible storage) ─────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"                   # true khi production dùng HTTPS
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="CHANGE_ME"
MINIO_BUCKET="traotay"
MINIO_PUBLIC_URL="http://localhost:9000"   # Dev; production "https://s3.traotay.com.vn"

# ─── Email (Resend) ────────────────────────────────────────────────
# Rỗng khi dev → OTP in ra console (chỉ non-production). Production bắt buộc có.
RESEND_API_KEY=""

# ─── Dev/debug endpoints secret ────────────────────────────────────
# Bảo vệ /dev/* endpoints. Production KHÔNG cần set — dev endpoints tự disable
# khi NODE_ENV=production dù DEV_SECRET có đúng hay không.
DEV_SECRET=""

# ─── PayOS — Cổng thanh toán QR VietQR ─────────────────────────────
# Lấy từ my.payos.vn → Kênh thanh toán → API Keys
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""

# ─── Sentry error tracking ─────────────────────────────────────────
# Tạo project tại sentry.io → Settings → Client Keys (DSN). Free 5k events/tháng.
# Rỗng = tắt Sentry. Production warn nếu rỗng.
SENTRY_DSN=""
# (Optional) commit SHA — set khi deploy để Sentry group lỗi theo release
SENTRY_RELEASE=""

# ─── Google Play reviewer backdoor ─────────────────────────────────
# Trao Tay dùng OTP login (không password). Reviewer Google Play không tự
# nhận OTP qua email được → cần backdoor login bypass OTP store.
# - Phải set CẢ 2 mới enable (chỉ set 1 → safety disable backdoor)
# - Email + OTP fix dùng cho Play Console "Quyền truy cập vào ứng dụng" form
# - KHÔNG để credentials lọt ra ngoài Console review
GOOGLE_REVIEW_EMAIL=""                  # VD: "google-review@traotay.com.vn"
GOOGLE_REVIEW_OTP=""                    # VD: 6 chữ số fix

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app"

# JWT
JWT_SECRET="your-secret-key-here"

# Server
PORT=3800
BASE_URL="http://your-server-ip:3800"

# Firebase Cloud Messaging (FCM)
# Đặt nội dung file JSON service account vào đây (1 dòng) hoặc dùng GOOGLE_APPLICATION_CREDENTIALS
# FCM_SERVICE_ACCOUNT='{"type":"service_account","project_id":"..."}'

# Dev/debug endpoints secret (bảo vệ /dev/* endpoints khỏi public access)
DEV_SECRET="your-dev-secret-here"

# PayOS — Cổng thanh toán QR VietQR (lấy từ my.payos.vn → Kênh thanh toán → API Keys)
PAYOS_CLIENT_ID="your-payos-client-id"
PAYOS_API_KEY="your-payos-api-key"
PAYOS_CHECKSUM_KEY="your-payos-checksum-key"

# ══════════════════════════════════════════════════════════════════
# .env.production.example — copy sang .env.docker trên VPS
#
# Các bước:
#   1. cp .env.production.example .env.docker
#   2. nano .env.docker
#   3. Thay MỌI CHANGE_ME bằng giá trị thật (generate random ở cuối file)
#   4. chmod 600 .env.docker (chỉ owner đọc được)
#
# CẢNH BÁO: Không commit file này sau khi đã điền giá trị thật.
# ══════════════════════════════════════════════════════════════════

# ─── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3800
BASE_URL=https://api.traotay.com.vn
PUBLIC_URL=https://api.traotay.com.vn

# ─── CORS ──────────────────────────────────────────────────────────
# Comma-separated origin. Mobile app không bị ảnh hưởng (không có Origin header)
CORS_ORIGIN=https://traotay.com.vn,https://www.traotay.com.vn

# ─── Postgres ──────────────────────────────────────────────────────
POSTGRES_USER=traotay_app
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_32CHAR_PASSWORD
POSTGRES_DB=traotay
# Trong container network, host là "postgres" (service name)
DATABASE_URL=postgresql://traotay_app:CHANGE_ME_RANDOM_32CHAR_PASSWORD@postgres:5432/traotay

# ─── JWT ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# ─── Admin ─────────────────────────────────────────────────────────
# Comma-separated. User có email trong list này sẽ có role admin khi login.
ADMIN_EMAILS=admin@traotay.com.vn

# ─── Firebase Cloud Messaging ─────────────────────────────────────
# Copy nội dung file service-account.json, convert thành 1 dòng.
# Tip: cat firebase-service-account.json | tr -d '\n' | sed 's/"/\\"/g'
FCM_SERVICE_ACCOUNT=

# ─── MinIO ─────────────────────────────────────────────────────────
# Root user dùng để admin; tạo user riêng cho backend sau khi deploy lần đầu.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_RANDOM_32CHAR_PASSWORD
# Backend kết nối — host "minio" trong container network
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_RANDOM_32CHAR_PASSWORD
MINIO_BUCKET=traotay
# Public URL mà app/browser dùng để load ảnh (qua Nginx HTTPS)
MINIO_PUBLIC_URL=https://s3.traotay.com.vn

# ─── Email (Resend) ────────────────────────────────────────────────
# Lấy từ resend.com/api-keys. Bắt buộc — production thiếu sẽ throw khi gửi OTP.
RESEND_API_KEY=re_CHANGE_ME

# ─── Dev endpoints ─────────────────────────────────────────────────
# KHÔNG SET khi production — dev endpoints tự disable theo NODE_ENV=production.
# Để rỗng hoặc xóa dòng.
# DEV_SECRET=

# ─── PayOS — Cổng thanh toán ───────────────────────────────────────
# Lấy từ my.payos.vn → Kênh thanh toán → API Keys
PAYOS_CLIENT_ID=CHANGE_ME
PAYOS_API_KEY=CHANGE_ME
PAYOS_CHECKSUM_KEY=CHANGE_ME

# ══════════════════════════════════════════════════════════════════
# Script generate password random (chạy trên VPS):
#
#   for i in 1 2 3; do openssl rand -base64 32 | tr -d '/+=' | head -c 32; echo; done
#
# Dùng 3 password khác nhau cho: POSTGRES_PASSWORD, MINIO_ROOT_PASSWORD,
# MINIO_SECRET_KEY. JWT_SECRET generate riêng: openssl rand -base64 64
# ══════════════════════════════════════════════════════════════════

# API backend URL (mặc định production khi không set)
NEXT_PUBLIC_API_URL=https://api.traotay.com.vn

# Cloudflare Web Analytics token — privacy-first analytics
# Lấy: CF Dashboard → Analytics & Logs → Web Analytics → Add a site
#       → "traotay.com.vn" → token trong data-cf-beacon JSON
# Khi không set: component CloudflareAnalytics không render → KHÔNG log
# nhầm dev traffic vào dashboard prod.
NEXT_PUBLIC_CF_BEACON_TOKEN=
